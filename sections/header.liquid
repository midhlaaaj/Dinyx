<script>
  (function() {
    let currentCartData = null;
    let cartModified = false;
    let appliedCartCoupon = null;

    function formatCartPrice(val) {
      return 'Rs. ' + val.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' INR';
    }

    function updateCartModalTotals(subtotalVal) {
      const activeCard = document.querySelector('.dinyx-cart-shipping-card.active');
      const isFast = activeCard && activeCard.getAttribute('data-type') === 'fast';
      const shippingVal = isFast ? {{ settings.fast_shipping_price | default: 199 }} : 0;
      
      let discountValue = 0;
      const discountRow = document.getElementById('dinyx-cart-discount-row');
      const discountEl = document.getElementById('dinyx-cart-discount');
      const appliedCodeEl = document.getElementById('dinyx-cart-applied-code');

      if (appliedCartCoupon) {
        if (appliedCartCoupon.type === 'percentage') {
          discountValue = subtotalVal * (parseFloat(appliedCartCoupon.value) / 100.0);
        } else {
          discountValue = parseFloat(appliedCartCoupon.value);
        }
        if (discountValue > subtotalVal) {
          discountValue = subtotalVal;
        }
      }

      if (discountValue > 0) {
        if (discountRow) discountRow.style.display = 'flex';
        if (appliedCodeEl) appliedCodeEl.textContent = appliedCartCoupon.code;
        if (discountEl) discountEl.textContent = '- ' + formatCartPrice(discountValue);
      } else {
        if (discountRow) discountRow.style.display = 'none';
      }

      const totalVal = (subtotalVal - discountValue) + shippingVal;
      
      const shippingEl = document.getElementById('dinyx-cart-shipping');
      const totalEl = document.getElementById('dinyx-cart-total');
      
      if (shippingEl) {
        shippingEl.textContent = isFast ? formatCartPrice(shippingVal) : 'Free';
      }
      if (totalEl) {
        totalEl.textContent = formatCartPrice(totalVal);
      }
    }

    function renderCartModalItems(cart) {
      currentCartData = cart;
      const container = document.getElementById('dinyx-cart-modal-items');
      if (!container) return;
      
      if (!cart.items || cart.items.length === 0) {
        container.innerHTML = '<p style="text-align: center; font-size: 1.4rem; color: #767676; padding: 2rem 0;">Your cart is empty.</p>';
        document.getElementById('dinyx-cart-subtotal').textContent = formatCartPrice(0);
        updateCartModalTotals(0);
        return;
      }
      
      let html = '';
      cart.items.forEach(item => {
        const itemPrice = (item.price / 100.0);
        const itemTotalPrice = itemPrice * item.quantity;
        const imgUrl = item.image ? item.image : '';
        const variantTitle = item.variant_title ? item.variant_title : '';
        
        html += `
          <div class="dinyx-cart-item" data-key="${item.key}">
            <div class="dinyx-cart-item-image-wrapper">
              <img class="dinyx-cart-item-image" src="${imgUrl}" alt="${item.product_title}" loading="lazy">
              <span class="dinyx-cart-item-qty-badge">${item.quantity}</span>
            </div>
            <div class="dinyx-cart-item-details">
              <p class="dinyx-cart-item-title">${item.product_title}</p>
              <span class="dinyx-cart-item-variant">${variantTitle}</span>
            </div>
            <div class="dinyx-cart-item-price-remove">
              <span class="dinyx-cart-item-price">${formatCartPrice(itemTotalPrice)}</span>
              <button type="button" class="dinyx-cart-item-remove-btn" onclick="removeDinyxCartItem('${item.key}')">×</button>
            </div>
          </div>
        `;
      });
      
      container.innerHTML = html;
      
      const subtotalValue = cart.total_price / 100.0;
      document.getElementById('dinyx-cart-subtotal').textContent = formatCartPrice(subtotalValue);
      updateCartModalTotals(subtotalValue);
    }

    function initCartModalShipping() {
      const savedSpeed = localStorage.getItem('dinyx-cart-shipping-speed') || 'fast'; // Default to fast
      document.querySelectorAll('.dinyx-cart-shipping-card').forEach(card => {
        if (card.getAttribute('data-type') === savedSpeed) {
          card.classList.add('active');
        } else {
          card.classList.remove('active');
        }
      });
    }

    window.removeDinyxCartItem = function(itemKey) {
      const itemRow = document.querySelector(`.dinyx-cart-item[data-key="${itemKey}"]`);
      if (itemRow) {
        itemRow.style.opacity = '0.5';
        itemRow.style.pointerEvents = 'none';
      }
      
      fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          id: itemKey,
          quantity: 0
        })
      })
      .then(res => res.json())
      .then(cart => {
        cartModified = true;
        renderCartModalItems(cart);
      })
      .catch(err => {
        console.error('Error removing item:', err);
        if (itemRow) {
          itemRow.style.opacity = '1';
          itemRow.style.pointerEvents = 'auto';
        }
      });
    };

    function initCartCouponLogic() {
      const applyBtn = document.getElementById('dinyx-cart-coupon-apply-btn');
      const couponInput = document.getElementById('dinyx-cart-coupon');
      const msgEl = document.getElementById('dinyx-cart-coupon-message');

      if (applyBtn && !applyBtn.hasAttribute('data-listener')) {
        applyBtn.setAttribute('data-listener', 'true');
        applyBtn.addEventListener('click', function() {
          const rawCode = couponInput.value.trim().toUpperCase();
          if (!rawCode) {
            appliedCartCoupon = null;
            msgEl.style.display = 'none';
            if (currentCartData) {
              updateCartModalTotals(currentCartData.total_price / 100.0);
            }
            return;
          }

          let couponsData = [];
          try {
            couponsData = JSON.parse(document.getElementById('dinyx-coupons-data')?.textContent || '[]');
          } catch(e) {
            console.error(e);
          }

          const found = couponsData.find(c => c.code === rawCode);
          if (found) {
            appliedCartCoupon = found;
            msgEl.style.color = '#28a745';
            msgEl.textContent = `Coupon applied! (${found.type === 'percentage' ? found.value + '%' : 'Rs. ' + found.value} off)`;
            msgEl.style.display = 'block';
          } else {
            appliedCartCoupon = null;
            msgEl.style.color = '#ff5a5f';
            msgEl.textContent = 'Invalid coupon code.';
            msgEl.style.display = 'block';
          }
          if (currentCartData) {
            updateCartModalTotals(currentCartData.total_price / 100.0);
          }
        });
      }
    }

    function openDinyxCartModal() {
      const modalOverlay = document.getElementById('dinyx-cart-modal-overlay');
      if (!modalOverlay) return;
      
      initCartModalShipping();
      initCartCouponLogic();
      
      if (modalOverlay.parentElement !== document.body) {
        document.body.appendChild(modalOverlay);
      }
      modalOverlay.classList.add('active');
      document.body.classList.add('dinyx-modal-open', 'dinyx-scroll-lock');
      document.documentElement.classList.add('dinyx-scroll-lock');
      
      const itemsContainer = document.getElementById('dinyx-cart-modal-items');
      if (itemsContainer) {
        itemsContainer.innerHTML = '<p style="text-align: center; font-size: 1.4rem; padding: 2rem 0;">Loading cart details...</p>';
      }
      
      fetch('/cart.js')
        .then(res => res.json())
        .then(cart => {
          renderCartModalItems(cart);
        })
        .catch(err => {
          console.error('Error fetching cart:', err);
          if (itemsContainer) {
            itemsContainer.innerHTML = '<p style="text-align: center; font-size: 1.4rem; color: red; padding: 2rem 0;">Failed to load cart. Please try again.</p>';
          }
        });
    }

    // Intercept checkout clicks globally (Capturing Phase)
    document.addEventListener('click', function(e) {
      const checkoutBtn = e.target.closest('[name="checkout"], #checkout, #CartDrawer-Checkout, .cart__checkout-button');
      if (checkoutBtn) {
        e.preventDefault();
        e.stopPropagation();
        
        // Only open if cart is not empty (check using quick fetch or current data)
        fetch('/cart.js')
          .then(res => res.json())
          .then(cart => {
            if (cart.item_count > 0) {
              openDinyxCartModal();
            } else {
              alert('Your cart is empty.');
            }
          })
          .catch(() => {
            openDinyxCartModal();
          });
      }
    }, true);

    // Click handler inside modal (Shipping speed cards, submit, close)
    document.addEventListener('click', function(e) {
      // Shipping card selection
      const card = e.target.closest('.dinyx-cart-shipping-card');
      if (card) {
        document.querySelectorAll('.dinyx-cart-shipping-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        
        const type = card.getAttribute('data-type');
        localStorage.setItem('dinyx-cart-shipping-speed', type);
        
        if (currentCartData) {
          updateCartModalTotals(currentCartData.total_price / 100.0);
        }
        return;
      }

      // Close modal
      const closeBtn = e.target.closest('#dinyx-cart-modal-close');
      const isOverlayClick = e.target.matches('#dinyx-cart-modal-overlay');
      if (closeBtn || isOverlayClick) {
        const modalOverlay = document.getElementById('dinyx-cart-modal-overlay');
        if (modalOverlay && modalOverlay.classList.contains('active')) {
          modalOverlay.classList.remove('active');
          document.body.classList.remove('dinyx-modal-open', 'dinyx-scroll-lock');
          document.documentElement.classList.remove('dinyx-scroll-lock');
          if (cartModified) {
            window.location.reload();
          }
        }
        return;
      }

      // Submit COD order
      const submitBtn = e.target.closest('#dinyx-cart-submit-btn');
      if (submitBtn) {
        const form = document.getElementById('dinyx-cart-cod-form');
        if (!form) return;

        const nameEl = document.getElementById('dinyx-cart-name');
        const phoneEl = document.getElementById('dinyx-cart-phone');
        const addressEl = document.getElementById('dinyx-cart-address');
        const cityEl = document.getElementById('dinyx-cart-city');
        const stateEl = document.getElementById('dinyx-cart-state');
        const pincodeEl = document.getElementById('dinyx-cart-pincode');
        const landmarkEl = document.getElementById('dinyx-cart-landmark');

        const name = nameEl ? nameEl.value.trim() : '';
        const phone = phoneEl ? phoneEl.value.trim() : '';
        const address = addressEl ? addressEl.value.trim() : '';
        const city = cityEl ? cityEl.value.trim() : '';
        const state = stateEl ? stateEl.value.trim() : '';
        const pincode = pincodeEl ? pincodeEl.value.trim() : '';
        const landmark = landmarkEl ? landmarkEl.value.trim() : '';

        if (!name || !phone || !address || !city || !state || !pincode) {
          alert('Please fill out all required fields marked with *');
          return;
        }

        if (!currentCartData || !currentCartData.items || currentCartData.items.length === 0) {
          alert('Your cart is empty.');
          return;
        }

        submitBtn.textContent = 'PLACING ORDER...';
        submitBtn.disabled = true;

        const activeCard = document.querySelector('.dinyx-cart-shipping-card.active');
        const isFast = activeCard && activeCard.getAttribute('data-type') === 'fast';
        const shippingName = isFast ? 'Fast Delivery' : 'Standard Delivery';
        const shippingMode = isFast ? 'Fast' : 'Normal';
        const shippingVal = isFast ? {{ settings.fast_shipping_price | default: 199 }} : 0;
        const subtotalVal = currentCartData.total_price / 100.0;
        const totalVal = subtotalVal + shippingVal;

        const subtotalText = formatCartPrice(subtotalVal);
        const shippingText = isFast ? formatCartPrice(shippingVal) : 'Free';
        const totalText = formatCartPrice(totalVal);

        let itemsText = '';
        currentCartData.items.forEach((item, index) => {
          const variantText = item.variant_title ? ` (${item.variant_title})` : '';
          const itemPrice = (item.price / 100.0);
          const itemTotalPrice = itemPrice * item.quantity;
          const itemUrl = window.location.origin + item.url;
          itemsText += `- Product ${index + 1}: ${item.product_title}${variantText} x ${item.quantity} = ${formatCartPrice(itemTotalPrice)}\n  Link: ${itemUrl}\n`;
        });

        const discountRow = document.getElementById('dinyx-cart-discount-row');
        const isDiscountApplied = discountRow && discountRow.style.display !== 'none';
        const discountVal = isDiscountApplied ? document.getElementById('dinyx-cart-discount').textContent.trim() : '';

        const waMessage = `Hello dynix.in! I'd like to place a Cash on Delivery order for the following items:\n\n` +
          `${itemsText}\n` +
          `Subtotal: ${subtotalText}\n` +
          (isDiscountApplied ? `- Discount: ${discountVal}\n` : '') +
          (appliedCartCoupon ? `- Coupon Code: ${appliedCartCoupon.code}\n` : '') +
          `Shipping Mode: ${shippingMode}\n` +
          `Shipping (${shippingName}): ${shippingText}\n` +
          `Total: ${totalText}\n\n` +
          `Customer Details:\n` +
          `- Name: ${name}\n` +
          `- Phone: ${phone}\n` +
          `- Address: ${address}\n` +
          `- City: ${city}\n` +
          `- State: ${state}\n` +
          `- Pin Code: ${pincode}\n` +
          `- Landmark: ${landmark || 'N/A'}`;

        const waNumber = '918075356149';
        const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;

        window.open(waUrl, '_blank');
        form.classList.add('hidden');
        document.getElementById('dinyx-cart-success-message').classList.remove('hidden');
        submitBtn.textContent = 'ORDER PLACED ✓';

        // Clear cart in Shopify since order is placed
        fetch('/cart/clear.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          }
        })
        .then(() => {
          setTimeout(() => {
            const modalOverlay = document.getElementById('dinyx-cart-modal-overlay');
            if (modalOverlay) {
              modalOverlay.classList.remove('active');
              document.body.classList.remove('dinyx-modal-open', 'dinyx-scroll-lock');
              document.documentElement.classList.remove('dinyx-scroll-lock');
            }
            window.location.reload();
          }, 3000);
        })
        .catch(err => {
          console.error('Error clearing cart:', err);
          setTimeout(() => {
            window.location.reload();
          }, 3000);
        });
      }
    });
  })();
</script>

