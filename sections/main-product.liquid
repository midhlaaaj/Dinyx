<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}
  {%- if product.quantity_price_breaks_configured? -%}
    {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    /* Custom COD Checkout Form Styles */
    .dinyx-cod-checkout-form-container {
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .dinyx-cod-card {
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      padding: 2.5rem;
      background-color: #ffffff;
    }

    .dinyx-cod-title {
      margin-top: 0;
      margin-bottom: 2rem;
      font-family: 'Urbanist', sans-serif !important;
      font-weight: 700;
      font-size: 1.8rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #000000;
    }

    .dinyx-cod-summary {
      border-bottom: 1px dashed #e5e5e5;
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
    }

    .dinyx-cod-summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 1rem;
      font-size: 1.4rem;
      color: #555555;
    }

    .dinyx-cod-summary-row span:last-child {
      font-weight: 600;
      color: #000000;
    }

    .dinyx-cod-summary-row.total-row {
      font-size: 1.8rem;
      font-weight: 800;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid #e5e5e5;
      color: #000000;
    }

    .dinyx-cod-summary-row.total-row span:last-child {
      font-weight: 900;
      color: #000000;
    }

    .dinyx-cod-form-fields {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .dinyx-cod-field {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .dinyx-cod-field label {
      font-size: 1.3rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #333333;
    }

    .dinyx-cod-field label .required {
      color: #ff2a5f;
    }

    .dinyx-input-wrapper {
      display: flex;
      align-items: center;
      border: 1px solid #dcdcdc;
      border-radius: 4px;
      padding: 0 1.2rem;
      background-color: #fafafa;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .dinyx-input-wrapper:focus-within {
      border-color: #000000;
      background-color: #ffffff;
      box-shadow: 0 0 0 1px #000000;
    }

    .dinyx-field-icon {
      font-size: 1.6rem;
      margin-right: 1rem;
      color: #666666;
    }

    .dinyx-input-wrapper input {
      border: none !important;
      background: transparent !important;
      padding: 1.2rem 0 !important;
      font-size: 1.4rem !important;
      font-family: 'Urbanist', sans-serif !important;
      width: 100% !important;
      color: #000000 !important;
      outline: none !important;
      box-shadow: none !important;
    }

    .dinyx-input-wrapper select {
      border: none !important;
      background: transparent !important;
      padding: 1.2rem 0 !important;
      font-size: 1.4rem !important;
      width: 100% !important;
      color: #000000 !important;
      outline: none !important;
      box-shadow: none !important;
      cursor: pointer;
    }

    .dinyx-cod-button {
      margin-top: 1rem;
      padding: 1.5rem !important;
      background-color: #000000 !important;
      color: #ffffff !important;
      border: none !important;
      font-family: 'Urbanist', sans-serif !important;
      font-weight: 800 !important;
      font-size: 1.5rem !important;
      letter-spacing: 0.1em !important;
      text-transform: uppercase !important;
      cursor: pointer !important;
      border-radius: 4px !important;
      transition: background-color 0.2s ease !important;
      text-align: center !important;
      width: 100% !important;
    }

    .dinyx-cod-button:hover {
      background-color: #333333 !important;
    }

    .dinyx-cod-button:disabled {
      background-color: #666666 !important;
      cursor: not-allowed !important;
    }

    .dinyx-cod-success {
      text-align: center;
      padding: 2rem 0;
    }

    .success-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 6rem;
      height: 6rem;
      border-radius: 50%;
      background-color: #e8f5e9;
      color: #2e7d32;
      font-size: 3rem;
      font-weight: bold;
      margin-bottom: 1.5rem;
    }

    .dinyx-cod-success h4 {
      margin: 0 0 1rem 0;
      font-size: 2rem;
      font-weight: 800;
      color: #000000;
    }

    .dinyx-cod-success p {
      margin: 0;
      font-size: 1.4rem;
      color: #555555;
      line-height: 1.5;
    }

    .hidden {
      display: none !important;
    }

    /* Modal Overlay & Glassmorphism Styles */
    .dinyx-modal-overlay {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      background-color: rgba(0, 0, 0, 0.7) !important;
      backdrop-filter: blur(15px) !important;
      -webkit-backdrop-filter: blur(15px) !important;
      z-index: 100000 !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: flex-start !important;
      align-items: center !important;
      overflow-y: auto !important;
      padding: 1.5rem 1rem !important;
      opacity: 0 !important;
      pointer-events: none !important;
      transition: opacity 0.3s ease !important;
    }

    .dinyx-modal-overlay.active {
      opacity: 1 !important;
      pointer-events: auto !important;
    }

    .dinyx-modal-container {
      background-color: #ffffff !important;
      border-radius: 12px !important;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3) !important;
      width: 100% !important;
      max-width: 500px !important;
      padding: 2rem !important;
      position: relative !important;
      transform: scale(0.9) !important;
      transition: transform 0.3s ease !important;
      margin: auto 0 !important;
      box-sizing: border-box !important;
    }

    .dinyx-modal-overlay.active .dinyx-modal-container {
      transform: scale(1) !important;
    }

    @media screen and (min-width: 750px) {
      .dinyx-modal-overlay {
        padding: 3rem 1.5rem !important;
      }
      .dinyx-modal-container {
        padding: 3rem !important;
      }
    }

    .dinyx-modal-close-btn {
      position: absolute !important;
      top: 1.2rem !important;
      right: 1.5rem !important;
      background: transparent !important;
      border: none !important;
      font-size: 2.6rem !important;
      cursor: pointer !important;
      color: #888888 !important;
      line-height: 1 !important;
      padding: 0.5rem !important;
      transition: color 0.2s ease !important;
      z-index: 10 !important;
    }

     .dinyx-modal-close-btn:hover {
       color: #000000 !important;
     }

     body.dinyx-modal-open .sticky-bottom-action-container {
       display: none !important;
     }

     .dinyx-cod-row {
       display: flex !important;
       gap: 1rem !important;
       flex-wrap: wrap !important;
     }
     .dinyx-cod-row > .dinyx-cod-field {
       flex: 1 1 200px !important;
       margin-bottom: 0 !important;
     }
   {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- if product.quantity_price_breaks_configured? -%}
    <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
  <div class="page-width">
    <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}">
      <div class="grid__item product__media-wrapper">
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>
      <div class="product__info-wrapper grid__item{% if settings.page_width > 1400 and section.settings.media_size == "small" %} product__info-wrapper--extra-padding{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <section
          id="ProductInfo-{{ section.id }}"
          class="product__info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
        >
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                <p
                  class="product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </p>
              {%- when 'title' -%}
                <div class="product__title" {{ block.shopify_attributes }}>
                  <h1>{{ product.title | escape }}</h1>
                  <a href="{{ product.url }}" class="product__title">
                    <h2 class="h1">
                      {{ product.title | escape }}
                    </h2>
                  </a>
                </div>
              {%- when 'price' -%}
                <div id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    show_badges: true,
                    price_class: 'price--large'
                  -%}
                </div>
                {%- if product.quantity_price_breaks_configured? -%}
                  <div class="volume-pricing-note" id="Volume-Note-{{ section.id }}">
                    <span>{{ 'products.product.volume_pricing.note' | t }}</span>
                  </div>
                {%- endif -%}
                {%- if cart.taxes_included or cart.duties_included or shop.shipping_policy.body != blank -%}
                  <div class="product__tax caption rte">
                    {%- if cart.duties_included and cart.taxes_included -%}
                      {{ 'products.product.duties_and_taxes_included' | t }}
                    {%- elsif cart.taxes_included -%}
                      {{ 'products.product.taxes_included' | t }}
                    {%- elsif cart.duties_included -%}
                      {{ 'products.product.duties_included' | t }}
                    {%- endif -%}
                    {%- if shop.shipping_policy.body != blank -%}
                      {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                    {%- endif -%}
                  </div>
                {%- endif -%}
                
                <div class="dinyx-delivery-estimator">
                  <div class="dinyx-delivery-estimator__icon">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                  </div>
                  <div class="dinyx-delivery-estimator__text">
                    Estimated Delivery: <strong id="dinyx-delivery-date-display">Calculating...</strong>
                  </div>
                </div>
                <div {{ block.shopify_attributes }}>
                  {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                  {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    {{ form | payment_terms }}
                  {%- endform -%}
                </div>
              {%- when 'inventory' -%}
                <p
                  class="product__inventory{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                  {{ block.shopify_attributes }}
                  id="Inventory-{{ section.id }}"
                  role="status"
                >
                  {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                      {%- if product.selected_or_first_available_variant.inventory_quantity
                          <= block.settings.inventory_threshold
                      -%}
                        <span class="svg-wrapper" style="color: rgb(238, 148, 65)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_low_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_low_stock' | t -}}
                        {%- endif -%}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_in_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_in_stock' | t -}}
                        {%- endif -%}
                      {%- endif -%}
                    {%- else -%}
                      {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(200, 200, 200)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock' | t -}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                </p>
              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
                    {{ product.description }}
                  </div>
                {%- endif -%}
              {%- when 'sku' -%}
                <p
                  class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                  id="Sku-{{ section.id }}"
                  role="status"
                  {{ block.shopify_attributes }}
                >
                  <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                  {{- product.selected_or_first_available_variant.sku -}}
                </p>
              {%- when 'custom_liquid' -%}
                {{ block.settings.custom_liquid }}
              {%- when 'collapsible_tab' -%}
                <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                  <details id="Details-{{ block.id }}-{{ section.id }}">
                    <summary>
                      <div class="summary__title">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                        <h2 class="h4 accordion__title inline-richtext">
                          {{ block.settings.heading | default: block.settings.page.title | escape }}
                        </h2>
                      </div>
                      {{- 'icon-caret.svg' | inline_asset_content -}}
                    </summary>
                    <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                      {{ block.settings.content }}
                      {{ block.settings.page.content }}
                    </div>
                  </details>
                </div>
              {%- when 'quantity_selector' -%}
                <div
                  id="Quantity-Form-{{ section.id }}"
                  class="product-form__input product-form__quantity{% if settings.inputs_shadow_vertical_offset != 0 and settings.inputs_shadow_vertical_offset < 0 %} product-form__quantity-top{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {% comment %} TODO: enable theme-check once `item_count_for_variant` is accepted as valid filter {% endcomment %}
                  {% # theme-check-disable %}
                  {%- assign cart_qty = cart
                    | item_count_for_variant: product.selected_or_first_available_variant.id
                  -%}
                  {% # theme-check-enable %}
                  <span class="visually-hidden" id="quantity-label-{{ section.id }}">
                    {%- if cart_qty > 0 -%}
                      {{- 'products.product.quantity.in_cart_aria_label' | t: quantity: cart_qty -}}
                    {%- else -%}
                      {{- 'products.product.quantity.label' | t -}}
                    {%- endif -%}
                  </span>
                  <label
                    class="quantity__label form__label"
                    for="Quantity-{{ section.id }}"
                    aria-labelledby="quantity-label-{{ section.id }}"
                  >
                    <span aria-hidden="true">{{ 'products.product.quantity.label' | t }}</span>
                    <span class="quantity__rules-cart{% if cart_qty == 0 %} hidden{% endif %}" aria-hidden="true">
                      {%- render 'loading-spinner' -%}
                      <span
                        >(
                        {{- 'products.product.quantity.in_cart_html' | t: quantity: cart_qty -}}
                        )</span
                      >
                    </span>
                  </label>
                  <div class="price-per-item__container">
                    <quantity-input class="quantity" data-url="{{ product.url }}" data-section="{{ section.id }}">
                      <button class="quantity__button" name="minus" type="button">
                        <span class="visually-hidden">
                          {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                        </span>
                        <span class="svg-wrapper">
                          {{- 'icon-minus.svg' | inline_asset_content -}}
                        </span>
                      </button>
                      <input
                        class="quantity__input"
                        type="number"
                        name="quantity"
                        id="Quantity-{{ section.id }}"
                        data-cart-quantity="{{ cart_qty }}"
                        data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                          data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                          max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                        {% endif %}
                        step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                        value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        form="{{ product_form_id }}"
                      >
                      <button class="quantity__button" name="plus" type="button">
                        <span class="visually-hidden">
                          {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                        </span>
                        <span class="svg-wrapper">
                          {{- 'icon-plus.svg' | inline_asset_content -}}
                        </span>
                      </button>
                    </quantity-input>
                    {%- liquid
                      assign volume_pricing_array = product.selected_or_first_available_variant.quantity_price_breaks | sort: 'quantity' | reverse
                      assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.min
                      if cart_qty > 0
                        assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.increment
                      endif
                    -%}
                    {%- if product.quantity_price_breaks_configured? -%}
                      <price-per-item
                        id="Price-Per-Item-{{ section.id }}"
                        data-section-id="{{ section.id }}"
                        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      >
                        {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                          {%- assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price -%}
                          <div class="price-per-item">
                            {%- if variant_price_compare -%}
                              <dl class="price-per-item--current">
                                <dt class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </dt>
                                <dd>
                                  <s class="variant-item__old-price">
                                    {{ variant_price_compare | money_with_currency }}
                                  </s>
                                </dd>
                              </dl>
                            {%- endif -%}
                            {%- if current_qty_for_volume_pricing < volume_pricing_array.last.minimum_quantity -%}
                              {%- assign variant_price = product.selected_or_first_available_variant.price
                                | money_with_currency
                              -%}
                              <span class="price-per-item--current">
                                {{- 'products.product.volume_pricing.price_at_each_html' | t: price: variant_price -}}
                              </span>
                            {%- else -%}
                              {%- for price_break in volume_pricing_array -%}
                                {%- if current_qty_for_volume_pricing >= price_break.minimum_quantity -%}
                                  {%- assign price_break_price = price_break.price | money_with_currency -%}
                                  <span class="price-per-item--current">
                                    {{-
                                      'products.product.volume_pricing.price_at_each_html'
                                      | t: price: price_break_price
                                    -}}
                                  </span>
                                  {%- break -%}
                                {%- endif -%}
                              {%- endfor -%}
                            {%- endif -%}
                          </div>
                        {%- else -%}
                          {%- assign variant_price = product.selected_or_first_available_variant.price
                            | money_with_currency
                          -%}
                          {%- assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price -%}
                          <div class="price-per-item">
                            {%- if variant_price_compare -%}
                              <dl class="price-per-item--current">
                                <dt class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </dt>
                                <dd>
                                  <s class="variant-item__old-price">
                                    {{ variant_price_compare | money_with_currency }}
                                  </s>
                                </dd>
                                <dt class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </dt>
                                <dd>
                                  <span class="price-per-item--current">
                                    {{-
                                      'products.product.volume_pricing.price_at_each_html'
                                      | t: price: variant_price
                                    -}}
                                  </span>
                                </dd>
                              </dl>
                            {%- else -%}
                              <span class="price-per-item--current">
                                {{- 'products.product.volume_pricing.price_at_each_html' | t: price: variant_price -}}
                              </span>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      </price-per-item>
                    {%- endif -%}
                  </div>
                  <div class="quantity__rules caption" id="Quantity-Rules-{{ section.id }}">
                    {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 -%}
                      <span class="divider">
                        {{-
                          'products.product.quantity.multiples_of'
                          | t: quantity: product.selected_or_first_available_variant.quantity_rule.increment
                        -}}
                      </span>
                    {%- endif -%}
                    {%- if product.selected_or_first_available_variant.quantity_rule.min > 1 -%}
                      <span class="divider">
                        {{-
                          'products.product.quantity.minimum_of'
                          | t: quantity: product.selected_or_first_available_variant.quantity_rule.min
                        -}}
                      </span>
                    {%- endif -%}
                    {%- if product.selected_or_first_available_variant.quantity_rule.max != null -%}
                      <span class="divider">
                        {{-
                          'products.product.quantity.maximum_of'
                          | t: quantity: product.selected_or_first_available_variant.quantity_rule.max
                        -}}
                      </span>
                    {%- endif -%}
                  </div>
                  {%- if product.quantity_price_breaks_configured? -%}
                    <volume-pricing class="parent-display" id="Volume-{{ section.id }}">
                      {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                        <span class="caption-large">{{ 'products.product.volume_pricing.title' | t }}</span>
                        <ul class="list-unstyled">
                          <li>
                            <span>{{ product.selected_or_first_available_variant.quantity_rule.min }}+</span>
                            {%- assign price = product.selected_or_first_available_variant.price
                              | money_with_currency
                            -%}
                            <span data-text="{{ 'products.product.volume_pricing.price_at_each_html' | t: price: variant_price }}">
                              {{- 'sections.quick_order_list.each' | t: money: price -}}
                            </span>
                          </li>
                          {%- for price_break in product.selected_or_first_available_variant.quantity_price_breaks -%}
                            {%- assign price_break_price = price_break.price | money_with_currency -%}
                            <li class="{%- if forloop.index >= 3 -%}show-more-item hidden{%- endif -%}">
                              <span>
                                {{- price_break.minimum_quantity -}}
                                <span aria-hidden="true">+</span></span
                              >
                              <span data-text="{{ 'products.product.volume_pricing.price_at_each_html' | t: price: price_break_price }}">
                                {{- 'sections.quick_order_list.each' | t: money: price_break_price -}}
                              </span>
                            </li>
                          {%- endfor -%}
                        </ul>
                        {%- if product.selected_or_first_available_variant.quantity_price_breaks.size >= 3 -%}
                          <show-more-button>
                            <button
                              class="button-show-more link underlined-link"
                              id="Show-More-{{ section.id }}"
                              type="button"
                            >
                              <span class="label-show-more label-text"
                                ><span aria-hidden="true">+ </span>{{ 'products.facets.show_more' | t }}
                              </span>
                            </button>
                          </show-more-button>
                        {%- endif -%}
                      {%- endif -%}
                    </volume-pricing>
                  {%- endif -%}
                </div>
              {%- when 'popup' -%}
                <modal-opener
                  class="product-popup-modal__opener quick-add-hidden"
                  data-modal="#PopupModal-{{ block.id }}"
                  {{ block.shopify_attributes }}
                >
                  <button
                    id="ProductPopup-{{ block.id }}"
                    class="product-popup-modal__button link"
                    type="button"
                    aria-haspopup="dialog"
                  >
                    {{ block.settings.text | default: block.settings.page.title | escape }}
                  </button>
                </modal-opener>
              {%- when 'share' -%}
                {% liquid
                  assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
                  render 'share-button', block: block, share_link: share_url
                %}

              {%- when 'variant_picker' -%}
                {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
              {%- when 'buy_buttons' -%}
                {%- render 'buy-buttons',
                  block: block,
                  product: product,
                  product_form_id: product_form_id,
                  section_id: section.id,
                  show_pickup_availability: true
                -%}
              {%- when 'shipping_speed' -%}
                <div class="dinyx-shipping-speed" {{ block.shopify_attributes }}>
                  <div class="dinyx-shipping-speed__title-container">
                    <span class="dinyx-shipping-speed__title">Select Shipping Speed</span>
                    <span class="dinyx-shipping-speed__info-icon">
                      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                      </svg>
                    </span>
                  </div>
                  
                  <div class="dinyx-shipping-speed__options">
                    <div class="dinyx-shipping-card active" data-type="fast" data-days-min="{{ settings.fast_shipping_days_min | default: 4 }}" data-days-max="{{ settings.fast_shipping_days_max | default: 5 }}">
                      <div class="dinyx-shipping-card__badge">RECOMMENDED</div>
                      <div class="dinyx-shipping-card__content">
                        <div class="dinyx-shipping-card__icon-text">
                          <span class="dinyx-shipping-card__icon">⚡</span>
                          <span class="dinyx-shipping-card__name">Fast Delivery</span>
                        </div>
                        <div class="dinyx-shipping-card__indicator">
                          <span class="dinyx-shipping-card__check-circle"></span>
                        </div>
                      </div>
                      <div class="dinyx-shipping-card__days">{{ settings.fast_shipping_days_min | default: 4 }} - {{ settings.fast_shipping_days_max | default: 5 }} Days</div>
                      <div class="dinyx-shipping-card__price">Rs. {{ settings.fast_shipping_price | default: 199 }}.00 extra</div>
                    </div>
                    
                    <div class="dinyx-shipping-card" data-type="standard" data-days-min="{{ settings.standard_shipping_days_min | default: 7 }}" data-days-max="{{ settings.standard_shipping_days_max | default: 12 }}">
                      <div class="dinyx-shipping-card__content">
                        <div class="dinyx-shipping-card__icon-text">
                          <span class="dinyx-shipping-card__icon">📦</span>
                          <span class="dinyx-shipping-card__name">Standard Delivery</span>
                        </div>
                        <div class="dinyx-shipping-card__indicator">
                          <span class="dinyx-shipping-card__check-circle"></span>
                        </div>
                      </div>
                      <div class="dinyx-shipping-card__days">{{ settings.standard_shipping_days_min | default: 7 }} - {{ settings.standard_shipping_days_max | default: 12 }} Days</div>
                      <div class="dinyx-shipping-card__price">FREE</div>
                    </div>
                  </div>
                  
                  <div class="dinyx-shipping-delivery-date" id="dinyx-delivery-date-text">
                    Loading delivery dates...
                  </div>
                </div>
              {%- when 'cod_checkout_form' -%}
                <div class="dinyx-cod-checkout-form-container" 
                     id="dinyx-cod-checkout-form-container"
                     data-default-price="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}"
                     data-currency-symbol="{{ cart.currency.symbol }}"
                     {{ block.shopify_attributes }}>
                  <script type="application/json" id="dinyx-variant-prices">
                    {
                      {%- for variant in product.variants -%}
                        "{{ variant.id }}": {{ variant.price | divided_by: 100.0 }}{%- unless forloop.last -%},{%- endunless -%}
                      {%- endfor -%}
                    }
                  </script>
                  
                  <!-- Coupons Config Data -->
                  <script type="application/json" id="dinyx-coupons-data">
                    [
                      {%- assign coupon_added = false -%}
                      {%- for i in (1..5) -%}
                        {%- assign key_code = 'coupon_code_' | append: i -%}
                        {%- assign key_type = 'coupon_type_' | append: i -%}
                        {%- assign key_value = 'coupon_value_' | append: i -%}
                        {%- assign code = settings[key_code] | strip -%}
                        {%- if code != blank -%}
                          {%- if coupon_added -%},{%- endif -%}
                          {
                            "code": {{ code | upcase | json }},
                            "type": {{ settings[key_type] | json }},
                            "value": {{ settings[key_value] | default: 0 }}
                          }
                          {%- assign coupon_added = true -%}
                        {%- endif -%}
                      {%- endfor -%}
                    ]
                  </script>
                  
                  <!-- Modal Overlay -->
                  <div class="dinyx-modal-overlay" id="dinyx-cod-modal-overlay">
                    <div class="dinyx-modal-container">
                      <button type="button" class="dinyx-modal-close-btn" id="dinyx-cod-modal-close">×</button>
                      
                      <div class="dinyx-cod-card" id="dinyx-cod-card-wrapper">
                        <h3 class="dinyx-cod-title">{{ block.settings.form_title | escape }}</h3>
                        
                        <div class="dinyx-cod-summary">
                          <div class="dinyx-cod-summary-row">
                            <span>Product</span>
                            <span id="dinyx-cod-product-name">{{ product.title | escape }}</span>
                          </div>
                          <div class="dinyx-cod-summary-row">
                            <span>Selected Variant</span>
                            <span id="dinyx-cod-variant-name">{{ product.selected_or_first_available_variant.title | escape }}</span>
                          </div>
                          <div class="dinyx-cod-summary-row">
                            <span>Subtotal</span>
                            <span id="dinyx-cod-subtotal">
                              {{ product.selected_or_first_available_variant.price | money }}
                            </span>
                          </div>
                          <div class="dinyx-cod-summary-row" id="dinyx-cod-discount-row" style="display: none; color: #ff5a5f;">
                            <span>Discount (<span id="dinyx-cod-applied-code"></span>)</span>
                            <span id="dinyx-cod-discount">-Rs. 0.00</span>
                          </div>
                          <div class="dinyx-cod-summary-row">
                            <span>Shipping</span>
                            <span id="dinyx-cod-shipping">Free</span>
                          </div>
                          <div class="dinyx-cod-summary-row total-row">
                            <span>Total</span>
                            <span id="dinyx-cod-total">
                              {{ product.selected_or_first_available_variant.price | money }}
                            </span>
                          </div>
                        </div>

                        <form id="dinyx-cod-form" class="dinyx-cod-form-fields" onsubmit="return false;">
                          <div class="dinyx-cod-field">
                            <label for="dinyx-cod-shipping-speed-select">Shipping Speed <span class="required">*</span></label>
                            <div class="dinyx-input-wrapper">
                              <span class="dinyx-field-icon">🚚</span>
                              <select id="dinyx-cod-shipping-speed-select">
                                <option value="standard">Standard Delivery ({{ settings.standard_shipping_days_min | default: 7 }}-{{ settings.standard_shipping_days_max | default: 12 }} Days) - Free</option>
                                <option value="fast">Fast Delivery ({{ settings.fast_shipping_days_min | default: 4 }}-{{ settings.fast_shipping_days_max | default: 5 }} Days) - Rs. {{ settings.fast_shipping_price | default: 199 }}.00</option>
                              </select>
                            </div>
                          </div>
                          <div class="dinyx-cod-field">
                            <label for="dinyx-cod-name">Full Name <span class="required">*</span></label>
                            <div class="dinyx-input-wrapper">
                              <span class="dinyx-field-icon">👤</span>
                              <input type="text" id="dinyx-cod-name" placeholder="First and Last name" required>
                            </div>
                          </div>
                          
                          <div class="dinyx-cod-field">
                            <label for="dinyx-cod-phone">Mobile Number <span class="required">*</span></label>
                            <div class="dinyx-input-wrapper">
                              <span class="dinyx-field-icon">📞</span>
                              <input type="tel" id="dinyx-cod-phone" placeholder="Mobile Number" required>
                            </div>
                          </div>

                          <div class="dinyx-cod-field">
                             <label for="dinyx-cod-address">Complete Full Address <span class="required">*</span></label>
                             <div class="dinyx-input-wrapper">
                               <span class="dinyx-field-icon">📍</span>
                               <input type="text" id="dinyx-cod-address" placeholder="House No. / Building Name / Street / Area" required>
                             </div>
                           </div>

                           <div class="dinyx-cod-row" style="display: flex; gap: 1rem;">
                             <div class="dinyx-cod-field" style="flex: 1;">
                               <label for="dinyx-cod-city">City <span class="required">*</span></label>
                               <div class="dinyx-input-wrapper">
                                 <span class="dinyx-field-icon">🏙️</span>
                                 <input type="text" id="dinyx-cod-city" placeholder="City" required>
                               </div>
                             </div>
                             <div class="dinyx-cod-field" style="flex: 1;">
                               <label for="dinyx-cod-state">State <span class="required">*</span></label>
                               <div class="dinyx-input-wrapper">
                                 <span class="dinyx-field-icon">🗺️</span>
                                 <input type="text" id="dinyx-cod-state" placeholder="State" required>
                               </div>
                             </div>
                           </div>

                           <div class="dinyx-cod-field">
                             <label for="dinyx-cod-pincode">Pin Code <span class="required">*</span></label>
                             <div class="dinyx-input-wrapper">
                               <span class="dinyx-field-icon">📮</span>
                               <input type="text" id="dinyx-cod-pincode" placeholder="6-digit Pin Code" required pattern="[0-9]{6}">
                             </div>
                           </div>

                           <div class="dinyx-cod-field">
                             <label for="dinyx-cod-landmark">Landmark (Famous Spot)</label>
                             <div class="dinyx-input-wrapper">
                               <span class="dinyx-field-icon">🏢</span>
                               <input type="text" id="dinyx-cod-landmark" placeholder="Nearby School, Hospital, Shop ...">
                             </div>
                           </div>

                          <!-- Coupon Code Field -->
                          <div class="dinyx-cod-field">
                            <label for="dinyx-cod-coupon">Have a Coupon Code?</label>
                            <div class="dinyx-input-wrapper" style="display: flex; gap: 1rem;">
                              <span class="dinyx-field-icon">🏷️</span>
                              <input type="text" id="dinyx-cod-coupon" placeholder="Enter Coupon Code" style="flex: 1; min-width: 0;">
                              <button type="button" id="dinyx-cod-coupon-apply-btn" class="button" style="padding: 0 1.5rem; min-height: 4.5rem; margin: 0; background: #000; color: #fff; border: 1px solid #ddd; border-radius: 4px; font-size: 1.2rem; cursor: pointer;">
                                APPLY
                              </button>
                            </div>
                            <div id="dinyx-cod-coupon-message" style="margin-top: 0.5rem; font-size: 1.2rem; font-weight: 500; display: none;"></div>
                          </div>

                          <button type="button" id="dinyx-cod-submit-btn" class="dinyx-cod-button btn-whatsapp-order">
                            <svg viewBox="0 0 24 24" fill="currentColor" style="width: 2rem; height: 2rem; margin-right: 0.8rem; vertical-align: middle;">
                              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.835-2.029c1.625.963 3.513 1.47 5.458 1.47 5.766 0 10.455-4.686 10.459-10.45 2-2.76 1.085-5.353.111-7.323-.974-1.969-2.545-3.536-4.516-4.505C16.424 2.147 14.269 1.63 12.008 1.63c-5.761 0-10.45 4.693-10.454 10.463-.002 2.012.518 3.971 1.502 5.679L2.012 21.99l4.88-1.28c.027.015.053.03.08.046-.008-.008-.016-.016-.024-.024zM18.06 14.77c-.328-.164-1.942-.958-2.242-1.069-.3-.109-.519-.164-.737.164-.219.328-.847 1.069-1.039 1.287-.192.219-.384.246-.712.083-1.077-.492-1.89-1.07-2.68-1.725-.632-.525-1.058-1.168-1.182-1.381-.124-.219-.014-.337.097-.447.1-.1.219-.255.328-.383.109-.128.146-.219.219-.364.073-.146.037-.273-.018-.383-.055-.109-.519-1.251-.712-1.716-.187-.45-.376-.388-.519-.395-.133-.006-.286-.007-.44-.007-.153 0-.404.057-.615.287-.211.23-.806.787-.806 1.92 0 1.133.824 2.222.937 2.373.113.15 1.624 2.48 3.935 3.477.55.237 1.057.414 1.417.528.552.176 1.055.15 1.453.091.442-.066 1.942-.794 2.215-1.53.273-.737.273-1.368.192-1.5-.08-.133-.296-.219-.624-.383z"/>
                            </svg>
                            BOOK ON WHATSAPP
                          </button>
                        </form>

                        <div id="dinyx-cod-success-message" class="dinyx-cod-success hidden">
                          <div class="success-icon" style="background-color: #25d366; color: white;">✓</div>
                          <h4>Order Details Prepared!</h4>
                          <p>We have redirected you to WhatsApp. Please send the pre-filled message in the chat to complete your booking.</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {%- when 'rating' -%}
                <div class="rating-wrapper dinyx-interactive-rating" data-product-id="{{ product.id }}" {{ block.shopify_attributes }}>
                  <span class="rating-instruction">Rate this product:</span>
                  <div class="rating-stars" role="slider" aria-label="Rate this product" aria-valuemin="1" aria-valuemax="5" aria-valuenow="5">
                    {%- for i in (1..5) -%}
                      <span class="star-btn" data-value="{{ i }}">
                        <svg class="icon icon-star" viewBox="0 0 24 24" width="24" height="24">
                          <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                        </svg>
                      </span>
                    {%- endfor -%}
                  </div>
                  <span class="rating-label">
                    <span class="rating-value" id="rating-value-{{ product.id }}">5.0</span>/5
                  </span>
                  <span class="rating-count-text">
                    (<span class="rating-count" id="rating-count-{{ product.id }}">12</span> reviews)
                  </span>
                </div>
              {%- when 'complementary' -%}
                <product-recommendations
                  class="complementary-products quick-add-hidden{% if block.settings.make_collapsible_row %} is-accordion{% endif %}{% if block.settings.enable_quick_add %} complementary-products-contains-quick-add{% endif %}"
                  data-url="{{ routes.product_recommendations_url }}?limit={{ block.settings.product_list_limit }}&intent=complementary"
                  data-section-id="{{ section.id }}"
                  data-product-id="{{ product.id }}"
                >
                  {%- if recommendations.performed and recommendations.products_count > 0 -%}
                    <aside
                      aria-label="{{ 'accessibility.complementary_products' | t }}"
                      {{ block.shopify_attributes -}}
                      {% if block.settings.make_collapsible_row %}
                        class="product__accordion accordion"
                      {% endif %}
                    >
                      <div class="complementary-products__container">
                        {%- if block.settings.make_collapsible_row -%}
                          <details id="Details-{{ block.id }}-{{ section.id }}" open>
                            <summary>
                        {%- endif %}
                        <div class="summary__title">
                          {%- if block.settings.make_collapsible_row -%}
                            {% render 'icon-accordion', icon: block.settings.icon %}
                            <h2 class="h4 accordion__title">{{ block.settings.block_heading }}</h2>
                          {%- else -%}
                            <h2 class="h3 accordion__title">{{ block.settings.block_heading }}</h2>
                          {%- endif -%}
                        </div>
                        {%- if block.settings.make_collapsible_row -%}
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                          </summary>
                        {%- endif -%}
                        <slideshow-component class="slider-mobile-gutter">
                          {%- assign number_of_slides = recommendations.products_count
                            | plus: 0.0
                            | divided_by: block.settings.products_per_page
                            | ceil
                          -%}
                          <div
                            id="Slider-{{ block.id }}"
                            class="contains-card contains-card--product complementary-slider grid grid--1-col slider slider--everywhere"
                            role="list"
                            {% if number_of_slides > 1 %}
                              aria-label="{{ 'general.slider.name' | t }}"
                            {% endif %}
                          >
                            {% assign skip_card_product_styles = false %}
                            {%- for i in (1..number_of_slides) -%}
                              <div
                                id="Slide-{{ block.id }}-{{ forloop.index }}"
                                class="complementary-slide complementary-slide--{{ settings.card_style }} grid__item slider__slide slideshow__slide"
                                tabindex="-1"
                                role="group"
                                {% if number_of_slides > 1 %}
                                  aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
                                  aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                {% endif %}
                              >
                                <ul class="list-unstyled" role="list">
                                  {%- for product in recommendations.products
                                    limit: block.settings.products_per_page
                                    offset: continue
                                  -%}
                                    <li>
                                      {%- if block.settings.enable_quick_add -%}
                                        {% assign quick_add = 'standard' %}
                                      {%- else -%}
                                        {% assign quick_add = 'none' %}
                                      {%- endif -%}
                                      {% render 'card-product',
                                        card_product: product,
                                        media_aspect_ratio: block.settings.image_ratio,
                                        show_secondary_image: false,
                                        lazy_load: false,
                                        skip_styles: skip_card_product_styles,
                                        quick_add: quick_add,
                                        section_id: section.id,
                                        horizontal_class: true,
                                        horizontal_quick_add: true
                                      %}
                                    </li>
                                    {%- assign skip_card_product_styles = true -%}
                                  {%- endfor -%}
                                </ul>
                              </div>
                            {%- endfor -%}
                          </div>
                          {%- if number_of_slides > 1 -%}
                            <div class="slider-buttons">
                              <button
                                type="button"
                                class="slider-button slider-button--prev"
                                name="previous"
                                aria-label="{{ 'general.slider.previous_slide' | t }}"
                              >
                                <span class="svg-wrapper">
                                  {{- 'icon-caret.svg' | inline_asset_content -}}
                                </span>
                              </button>
                              <div class="slider-counter slider-counter--{{ block.settings.pagination_style }}{% if block.settings.pagination_style == 'counter' or block.settings.pagination_style == 'numbers' %} caption{% endif %}">
                                {%- if block.settings.pagination_style == 'counter' -%}
                                  <span class="slider-counter--current">1</span>
                                  <span aria-hidden="true"> / </span>
                                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                                  <span class="slider-counter--total">{{ number_of_slides }}</span>
                                {%- else -%}
                                  <div class="slideshow__control-wrapper">
                                    {%- for i in (1..number_of_slides) -%}
                                      <button
                                        class="slider-counter__link slider-counter__link--{{ block.settings.pagination_style }} link"
                                        aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                        aria-controls="Slider-{{ block.id }}"
                                      >
                                        {%- if block.settings.pagination_style == 'numbers' -%}
                                          {{ forloop.index -}}
                                        {%- else -%}
                                          <span class="dot"></span>
                                        {%- endif -%}
                                      </button>
                                    {%- endfor -%}
                                  </div>
                                {%- endif -%}
                              </div>
                              <button
                                type="button"
                                class="slider-button slider-button--next"
                                name="next"
                                aria-label="{{ 'general.slider.next_slide' | t }}"
                              >
                                <span class="svg-wrapper">
                                  {{- 'icon-caret.svg' | inline_asset_content -}}
                                </span>
                              </button>
                            </div>
                          {%- endif -%}
                        </slideshow-component>
                        {%- if block.settings.make_collapsible_row -%}
                          </details>
                        {%- endif -%}
                      </div>
                    </aside>
                  {%- endif -%}
                  {{ 'component-card.css' | asset_url | stylesheet_tag }}
                  {{ 'component-complementary-products.css' | asset_url | stylesheet_tag }}
                  {%- if block.settings.enable_quick_add -%}
                    {{ 'quick-add.css' | asset_url | stylesheet_tag }}
                    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
                  {%- endif -%}
                </product-recommendations>
              {%- when 'icon-with-text' -%}
                {% render 'icon-with-text', block: block %}
            {%- endcase -%}
          {%- endfor -%}
          <a href="{{ product.url }}" class="link product__view-details animate-arrow">
            {{ 'products.product.view_full_details' | t }}
            {{- 'icon-arrow.svg' | inline_asset_content -}}
          </a>
        </section>
      </div>
    </div>

    {% render 'product-media-modal', variant_images: variant_images %}

    {% assign popups = section.blocks | where: 'type', 'popup' %}
    {%- for block in popups -%}
      <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
        <div
          role="dialog"
          aria-label="{{ block.settings.text }}"
          aria-modal="true"
          class="product-popup-modal__content"
          tabindex="-1"
        >
          <button
            id="ModalClose-{{ block.id }}"
            type="button"
            class="product-popup-modal__toggle"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
          <div class="product-popup-modal__content-info">
            <h1 class="h2">{{ block.settings.page.title | escape }}</h1>
            {{ block.settings.page.content }}
          </div>
        </div>
      </modal-dialog>
    {%- endfor -%}

    {%- if product.media.size > 0 -%}
      <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if first_3d_model -%}
      <script type="application/json" id="ProductJSON-{{ product.id }}">
        {{ product.media | where: 'media_type', 'model' | json }}
      </script>
      <script src="{{ 'product-model.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- liquid
      if product.selected_or_first_available_variant.featured_media
        assign seo_media = product.selected_or_first_available_variant.featured_media
      else
        assign seo_media = product.featured_media
      endif
    -%}

    <script type="application/ld+json">
      {{ product | structured_data }}
    </script>
    
    <script>
      (function() {
        const defaultRating = 5.0;
        const defaultCount = 12;

        function initRatings() {
          const ratingContainers = document.querySelectorAll('.dinyx-interactive-rating:not([data-dinyx-initialized])');
          ratingContainers.forEach(container => {
            container.setAttribute('data-dinyx-initialized', 'true');
            const productId = container.getAttribute('data-product-id');
            if (!productId) return;

            const valEl = container.querySelector('.rating-value');
            const countEl = container.querySelector('.rating-count');
            const stars = container.querySelectorAll('.star-btn');

            let savedRating = localStorage.getItem('dinyx-rating-' + productId);
            let userHasRated = localStorage.getItem('dinyx-has-rated-' + productId);

            let rating = defaultRating;
            let count = defaultCount;

            if (userHasRated) {
              const userRatingVal = parseFloat(savedRating) || 5.0;
              count = defaultCount + 1;
              rating = ((defaultRating * defaultCount) + userRatingVal) / count;
            }

            if (valEl) valEl.textContent = Number(rating).toFixed(1);
            if (countEl) countEl.textContent = count;

            stars.forEach(star => {
              const val = parseInt(star.getAttribute('data-value'));
              if (val <= Math.round(rating)) {
                star.classList.add('filled');
              } else {
                star.classList.remove('filled');
              }
            });
          });

          // Sync Card Ratings
          const cardRatings = document.querySelectorAll('.dinyx-card-rating:not([data-dinyx-initialized])');
          cardRatings.forEach(card => {
            card.setAttribute('data-dinyx-initialized', 'true');
            const productId = card.getAttribute('data-product-id');
            if (!productId) return;

            const valEl = card.querySelector('.rating-value');
            const countEl = card.querySelector('.rating-count');
            const stars = card.querySelectorAll('.star');

            let savedRating = localStorage.getItem('dinyx-rating-' + productId);
            let userHasRated = localStorage.getItem('dinyx-has-rated-' + productId);

            let rating = defaultRating;
            let count = defaultCount;

            if (userHasRated) {
              const userRatingVal = parseFloat(savedRating) || 5.0;
              count = defaultCount + 1;
              rating = ((defaultRating * defaultCount) + userRatingVal) / count;
            }

            if (valEl) valEl.textContent = Number(rating).toFixed(1);
            if (countEl) countEl.textContent = count;

            stars.forEach((star, index) => {
              if ((index + 1) <= Math.round(rating)) {
                star.classList.add('filled');
                star.textContent = '★';
              } else {
                star.classList.remove('filled');
                star.textContent = '☆';
              }
            });
          });
        }

        function calculateDeliveryDates() {
          const dateTextEl = document.getElementById('dinyx-delivery-date-text');
          if (!dateTextEl) return;

          const activeCard = document.querySelector('.dinyx-shipping-card.active');
          if (!activeCard) return;

          const minDays = parseInt(activeCard.getAttribute('data-days-min')) || 0;
          const maxDays = parseInt(activeCard.getAttribute('data-days-max')) || 0;

          const daysOfWeek = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
          const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

          function getFormattedDate(daysToAdd) {
            const d = new Date();
            d.setDate(d.getDate() + daysToAdd);
            const dayName = daysOfWeek[d.getDay()];
            const monthName = months[d.getMonth()];
            const dateNum = d.getDate();
            return `${dayName}, ${monthName} ${dateNum}`;
          }

          const startFormatted = getFormattedDate(minDays);
          const endFormatted = getFormattedDate(maxDays);

          dateTextEl.textContent = `Delivered by ${startFormatted} - ${endFormatted}`;
        }

        function initShipping() {
          const shippingBlock = document.querySelector('.dinyx-shipping-speed:not([data-dinyx-initialized])');
          if (shippingBlock) {
            shippingBlock.setAttribute('data-dinyx-initialized', 'true');
            // Restore active shipping speed from localStorage
            const savedSpeed = localStorage.getItem('dinyx-shipping-speed') || 'fast'; // Default to fast
            shippingBlock.querySelectorAll('.dinyx-shipping-card').forEach(card => {
              if (card.getAttribute('data-type') === savedSpeed) {
                card.classList.add('active');
              } else {
                card.classList.remove('active');
              }
            });
            calculateDeliveryDates();
          }
        }

        function updateCodFormDetails() {
          const codForm = document.querySelector('.dinyx-cod-checkout-form-container');
          if (!codForm) return;

          // 1. Get current variant ID
          const selectedVariantIdInput = document.querySelector('input[name="id"]');
          const selectedVariantId = selectedVariantIdInput ? selectedVariantIdInput.value : '';

          // 2. Parse price JSON or get attributes
          let subtotalValue = null;
          const pricesJsonEl = document.getElementById('dinyx-variant-prices');
          if (pricesJsonEl && selectedVariantId) {
            try {
              const variantPrices = JSON.parse(pricesJsonEl.textContent);
              if (variantPrices[selectedVariantId] !== undefined) {
                subtotalValue = parseFloat(variantPrices[selectedVariantId]);
              }
            } catch (e) {
              console.error("Error parsing variant prices JSON", e);
            }
          }

          // Fallback 1: Parse from page price element
          if (subtotalValue === null || subtotalValue <= 0) {
            const activePriceEl = document.querySelector('.price--large .price-item--last, .price--large .price-item--regular, .product__info-container .price-item--last, .product__info-container .price-item--regular, .price .price-item--last, .price .price-item--regular');
            if (activePriceEl) {
              const rawPriceText = activePriceEl.textContent.trim();
              const match = rawPriceText.match(/[\d,.]+/);
              if (match) {
                subtotalValue = parseFloat(match[0].replace(/,/g, '')) || null;
              }
            }
          }

          // Fallback 2: Read data-default-price attribute if subtotal is still null or 0
          if (subtotalValue === null || subtotalValue <= 0) {
            const defaultPriceVal = codForm.getAttribute('data-default-price');
            subtotalValue = parseFloat(defaultPriceVal) || 0;
          }

          // Set clean currency prefix (INR mapped to Rs. and formatted nicely with spaces)
          let currencyPrefix = codForm.getAttribute('data-currency-symbol') || 'Rs.';
          if (currencyPrefix === 'INR') {
            currencyPrefix = 'Rs.';
          }
          if (currencyPrefix && !currencyPrefix.endsWith(' ')) {
            currencyPrefix += ' ';
          }

          // 3. Shipping cost
          const activeShippingCard = document.querySelector('.dinyx-shipping-card.active');
          const isFastShipping = activeShippingCard && activeShippingCard.getAttribute('data-type') === 'fast';
          const shippingValue = isFastShipping ? {{ settings.fast_shipping_price | default: 199 }} : 0;

          // Formatting function
          function formatPrice(val, prefix) {
            return prefix + val.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
          }

          // 4. Calculate coupon discount
          let discountValue = 0;
          const discountRow = document.getElementById('dinyx-cod-discount-row');
          const discountEl = document.getElementById('dinyx-cod-discount');
          const appliedCodeEl = document.getElementById('dinyx-cod-applied-code');

          if (appliedCoupon) {
            if (appliedCoupon.type === 'percentage') {
              discountValue = subtotalValue * (parseFloat(appliedCoupon.value) / 100.0);
            } else {
              discountValue = parseFloat(appliedCoupon.value);
            }
            if (discountValue > subtotalValue) {
              discountValue = subtotalValue;
            }
          }

          if (discountValue > 0) {
            if (discountRow) discountRow.style.display = 'flex';
            if (appliedCodeEl) appliedCodeEl.textContent = appliedCoupon.code;
            if (discountEl) discountEl.textContent = '- ' + formatPrice(discountValue, currencyPrefix);
          } else {
            if (discountRow) discountRow.style.display = 'none';
          }

          const totalValue = (subtotalValue - discountValue) + shippingValue;

          const subtotalEl = document.getElementById('dinyx-cod-subtotal');
          const shippingEl = document.getElementById('dinyx-cod-shipping');
          const totalEl = document.getElementById('dinyx-cod-total');
          const variantEl = document.getElementById('dinyx-cod-variant-name');

          if (subtotalEl) subtotalEl.textContent = formatPrice(subtotalValue, currencyPrefix);
          if (shippingEl) shippingEl.textContent = isFastShipping ? formatPrice(shippingValue, currencyPrefix) : 'Free';
          if (totalEl) totalEl.textContent = formatPrice(totalValue, currencyPrefix);

          const selectEl = document.getElementById('dinyx-cod-shipping-speed-select');
          if (selectEl && activeShippingCard) {
            selectEl.value = activeShippingCard.getAttribute('data-type');
          }

          // Update variant option text and clean up sold out/unavailable tags
          if (variantEl && selectedVariantIdInput) {
            let selectedOptions = [];
            document.querySelectorAll('fieldset.product-form__input input:checked, variant-selects select').forEach(el => {
              if (el.tagName === 'SELECT') {
                selectedOptions.push(el.options[el.selectedIndex].text.trim());
              } else {
                const label = document.querySelector(`label[for="${el.id}"]`);
                if (label) {
                  selectedOptions.push(label.textContent.trim());
                }
              }
            });
            if (selectedOptions.length > 0) {
              let cleanedVariantText = selectedOptions.join(' / ');
              cleanedVariantText = cleanedVariantText
                .replace(/Variant sold out or unavailable|sold out|unavailable|out of stock/gi, '')
                .replace(/\s*-\s*$/, '')
                .trim();
              variantEl.textContent = cleanedVariantText || 'Default Title';
            }
          }
        }

        let appliedCoupon = null;

        function initCodForm() {
          const codForm = document.querySelector('.dinyx-cod-checkout-form-container:not([data-dinyx-initialized])');
          if (codForm) {
            codForm.setAttribute('data-dinyx-initialized', 'true');
            
            const activeShippingCard = document.querySelector('.dinyx-shipping-card.active');
            const selectEl = document.getElementById('dinyx-cod-shipping-speed-select');
            if (activeShippingCard && selectEl) {
              selectEl.value = activeShippingCard.getAttribute('data-type');
            }

            if (selectEl) {
              selectEl.addEventListener('change', function(event) {
                const selectedVal = event.target.value;
                const targetCard = document.querySelector(`.dinyx-shipping-card[data-type="${selectedVal}"]`);
                if (targetCard) {
                  targetCard.click();
                } else {
                  localStorage.setItem('dinyx-shipping-speed', selectedVal);
                  updateCodFormDetails();
                }
              });
            }

            // Coupon application logic
            const couponInput = document.getElementById('dinyx-cod-coupon');
            const applyBtn = document.getElementById('dinyx-cod-coupon-apply-btn');
            const msgEl = document.getElementById('dinyx-cod-coupon-message');

            if (applyBtn && couponInput && msgEl) {
              applyBtn.addEventListener('click', function() {
                const rawCode = couponInput.value.trim().toUpperCase();
                if (!rawCode) {
                  appliedCoupon = null;
                  msgEl.style.display = 'none';
                  updateCodFormDetails();
                  return;
                }

                let couponsData = [];
                try {
                  couponsData = JSON.parse(document.getElementById('dinyx-coupons-data')?.textContent || '[]');
                } catch(e) {
                  console.error(e);
                }

                const found = couponsData.find(c => c.code === rawCode);
                if (found) {
                  appliedCoupon = found;
                  msgEl.style.color = '#28a745';
                  msgEl.textContent = `Coupon applied! (${found.type === 'percentage' ? found.value + '%' : 'Rs. ' + found.value} off)`;
                  msgEl.style.display = 'block';
                } else {
                  appliedCoupon = null;
                  msgEl.style.color = '#ff5a5f';
                  msgEl.textContent = 'Invalid coupon code.';
                  msgEl.style.display = 'block';
                }
                updateCodFormDetails();
              });
            }

            updateCodFormDetails();
          }
        }

        let updateTimeout;
        function initAll() {
          initRatings();
          initShipping();
          initCodForm();
          updateCodFormDetails();
          
          clearTimeout(updateTimeout);
          updateTimeout = setTimeout(updateCodFormDetails, 100);
        }

        // 2. Global Event Delegation
        // Click handler
        document.addEventListener('click', function(e) {
          // Official green WhatsApp button click (custom liquid block) or Buy It Now button click
          const officialWaBtn = e.target.closest('.btn--buy-on-whatsapp:not(.btn--need-help)');
          const buyItNowBtn = e.target.closest('#dinyx-custom-buy-now') || e.target.closest('.shopify-payment-button') || e.target.closest('.shopify-payment-button__button');
          if (officialWaBtn || buyItNowBtn) {
            e.preventDefault(); // Intercept redirect
            e.stopPropagation();
            updateCodFormDetails(); // Ensure modal is up-to-date
            const modalOverlay = document.getElementById('dinyx-cod-modal-overlay');
            if (modalOverlay) {
              if (modalOverlay.parentElement !== document.body) {
                document.body.appendChild(modalOverlay);
              }
              modalOverlay.classList.add('active');
              document.body.classList.add('dinyx-modal-open', 'dinyx-scroll-lock');
              document.documentElement.classList.add('dinyx-scroll-lock');
            }
            return;
          }

          // Close modal on 'x' click or background overlay click
          const closeBtn = e.target.closest('#dinyx-cod-modal-close');
          const isOverlayClick = e.target.matches('#dinyx-cod-modal-overlay');
          if (closeBtn || isOverlayClick) {
            const modalOverlay = document.getElementById('dinyx-cod-modal-overlay');
            if (modalOverlay) {
              modalOverlay.classList.remove('active');
              document.body.classList.remove('dinyx-modal-open', 'dinyx-scroll-lock');
              document.documentElement.classList.remove('dinyx-scroll-lock');
            }
            return;
          }

          // Star button click
          const starBtn = e.target.closest('.star-btn');
          if (starBtn) {
            const container = starBtn.closest('.dinyx-interactive-rating');
            if (!container) return;
            const productId = container.getAttribute('data-product-id');
            if (!productId) return;

            const selectedVal = parseInt(starBtn.getAttribute('data-value'));
            localStorage.setItem('dinyx-rating-' + productId, selectedVal);
            localStorage.setItem('dinyx-has-rated-' + productId, 'true');

            const valEl = container.querySelector('.rating-value');
            const countEl = container.querySelector('.rating-count');
            const stars = container.querySelectorAll('.star-btn');

            const newCount = defaultCount + 1;
            const newRating = ((defaultRating * defaultCount) + selectedVal) / newCount;

            if (valEl) valEl.textContent = Number(newRating).toFixed(1);
            if (countEl) countEl.textContent = newCount;

            stars.forEach(star => {
              const val = parseInt(star.getAttribute('data-value'));
              if (val <= Math.round(newRating)) {
                star.classList.add('filled');
              } else {
                star.classList.remove('filled');
              }
            });

            // Trigger sync to cards
            document.querySelectorAll('.dinyx-card-rating[data-product-id="' + productId + '"]').forEach(card => {
              const cardValEl = card.querySelector('.rating-value');
              const cardCountEl = card.querySelector('.rating-count');
              const cardStars = card.querySelectorAll('.star');
              if (cardValEl) cardValEl.textContent = Number(newRating).toFixed(1);
              if (cardCountEl) cardCountEl.textContent = newCount;
              cardStars.forEach((star, index) => {
                if ((index + 1) <= Math.round(newRating)) {
                  star.classList.add('filled');
                  star.textContent = '★';
                } else {
                  star.classList.remove('filled');
                  star.textContent = '☆';
                }
              });
            });
            return;
          }

          // Shipping card click
          const shippingCard = e.target.closest('.dinyx-shipping-card');
          if (shippingCard) {
            const shippingBlock = shippingCard.closest('.dinyx-shipping-speed');
            if (!shippingBlock) return;
            shippingBlock.querySelectorAll('.dinyx-shipping-card').forEach(c => c.classList.remove('active'));
            shippingCard.classList.add('active');
            
            // Save selection to localStorage
            const type = shippingCard.getAttribute('data-type');
            localStorage.setItem('dinyx-shipping-speed', type);
            
            calculateDeliveryDates();
            updateCodFormDetails();
            return;
          }

          // Custom COD form Place Order Click
          const submitBtn = e.target.closest('#dinyx-cod-submit-btn');
          if (submitBtn) {
            const form = document.getElementById('dinyx-cod-form');
            if (!form) return;

            const nameEl = document.getElementById('dinyx-cod-name');
            const phoneEl = document.getElementById('dinyx-cod-phone');
            const addressEl = document.getElementById('dinyx-cod-address');
            const cityEl = document.getElementById('dinyx-cod-city');
            const stateEl = document.getElementById('dinyx-cod-state');
            const pincodeEl = document.getElementById('dinyx-cod-pincode');
            const landmarkEl = document.getElementById('dinyx-cod-landmark');

            const name = nameEl ? nameEl.value.trim() : '';
            const phone = phoneEl ? phoneEl.value.trim() : '';
            const address = addressEl ? addressEl.value.trim() : '';
            const city = cityEl ? cityEl.value.trim() : '';
            const state = stateEl ? stateEl.value.trim() : '';
            const pincode = pincodeEl ? pincodeEl.value.trim() : '';
            const landmark = landmarkEl ? landmarkEl.value.trim() : '';

            if (!name || !phone || !address || !city || !state || !pincode) {
              alert('Please fill out all required fields marked with *');
              return;
            }

            submitBtn.textContent = 'PLACING ORDER...';
            submitBtn.disabled = true;

            const prodName = document.getElementById('dinyx-cod-product-name').textContent;
            const varName = document.getElementById('dinyx-cod-variant-name').textContent;
            const subtotal = document.getElementById('dinyx-cod-subtotal').textContent.trim();
            const shipping = document.getElementById('dinyx-cod-shipping').textContent.trim();
            const total = document.getElementById('dinyx-cod-total').textContent.trim();

            const discountRow = document.getElementById('dinyx-cod-discount-row');
            const isDiscountApplied = discountRow && discountRow.style.display !== 'none';
            const discountVal = isDiscountApplied ? document.getElementById('dinyx-cod-discount').textContent.trim() : '';

            const waMessage = `Hello Dinyx Drips! I'd like to place a Cash on Delivery order:\n` +
              `- Product: ${prodName}\n` +
              `- Variant: ${varName}\n` +
              `- Subtotal: ${subtotal}\n` +
              (isDiscountApplied ? `- Discount: ${discountVal}\n` : '') +
              (appliedCoupon ? `- Coupon Code: ${appliedCoupon.code}\n` : '') +
              `- Shipping: ${shipping}\n` +
              `- Total: ${total}\n\n` +
              `Customer Details:\n` +
              `- Name: ${name}\n` +
              `- Phone: ${phone}\n` +
              `- Address: ${address}\n` +
              `- City: ${city}\n` +
              `- State: ${state}\n` +
              `- Pin Code: ${pincode}\n` +
              `- Landmark: ${landmark || 'N/A'}`;

            const waNumber = '918075356149';
            const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;

            window.open(waUrl, '_blank');
            form.classList.add('hidden');
            document.getElementById('dinyx-cod-success-message').classList.remove('hidden');
            submitBtn.textContent = 'ORDER PLACED ✓';

            // Auto close modal after showing success message, then reset form
            setTimeout(() => {
              const modalOverlay = document.getElementById('dinyx-cod-modal-overlay');
              if (modalOverlay) {
                modalOverlay.classList.remove('active');
                document.body.style.overflow = '';
              }
              setTimeout(() => {
                form.classList.remove('hidden');
                document.getElementById('dinyx-cod-success-message').classList.add('hidden');
                submitBtn.textContent = 'PLACE COD ORDER';
                submitBtn.disabled = false;
                nameEl.value = '';
                phoneEl.value = '';
                addressEl.value = '';
                if (cityEl) cityEl.value = '';
                if (stateEl) stateEl.value = '';
                if (pincodeEl) pincodeEl.value = '';
                if (landmarkEl) landmarkEl.value = '';
              }, 400);
            }, 3000);
          }
        });

        // Mouse hover handling for stars
        document.addEventListener('mouseover', function(e) {
          const starBtn = e.target.closest('.star-btn');
          if (starBtn) {
            const container = starBtn.closest('.dinyx-interactive-rating');
            if (!container) return;
            const hoverVal = parseInt(starBtn.getAttribute('data-value'));
            container.querySelectorAll('.star-btn').forEach(s => {
              const v = parseInt(s.getAttribute('data-value'));
              if (v <= hoverVal) {
                s.classList.add('hover');
              } else {
                s.classList.remove('hover');
              }
            });
          }
        });

        document.addEventListener('mouseout', function(e) {
          const starBtn = e.target.closest('.star-btn');
          if (starBtn) {
            const container = starBtn.closest('.dinyx-interactive-rating');
            if (!container) return;
            container.querySelectorAll('.star-btn').forEach(s => s.classList.remove('hover'));
          }
        });

        // 3. MutationObserver for DOM replacement (Variant swap)
        let initTimeout;
        const observer = new MutationObserver((mutations) => {
          let shouldInit = false;
          for (let mutation of mutations) {
            for (let node of mutation.addedNodes) {
              if (node.nodeType === 1) {
                if (node.closest && (
                  node.closest('.dinyx-cod-checkout-form-container') || 
                  node.closest('.dinyx-interactive-rating') || 
                  node.closest('.dinyx-shipping-speed')
                )) {
                  continue;
                }
                shouldInit = true;
                break;
              }
            }
            if (shouldInit) break;
          }
          if (shouldInit) {
            clearTimeout(initTimeout);
            initTimeout = setTimeout(initAll, 50);
          }
        });

        // 4. Set up listeners (Observe only product-info component)
        const productInfoEl = document.querySelector('product-info');
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => {
            initAll();
            if (productInfoEl) {
              observer.observe(productInfoEl, { childList: true, subtree: true });
            } else {
              observer.observe(document.body, { childList: true, subtree: true });
            }
          });
        } else {
          initAll();
          if (productInfoEl) {
            observer.observe(productInfoEl, { childList: true, subtree: true });
          } else {
            observer.observe(document.body, { childList: true, subtree: true });
          }
        }
      })();
    </script>
    {%- comment -%} Mobile Sticky Bottom Bar {%- endcomment -%}
    <div class="sticky-bottom-action-container medium-hide large-up-hide">
      <div class="sticky-bottom-action-container__info">
        <span class="sticky-bottom-action-container__title">{{ product.title | escape }}</span>
        <span class="sticky-bottom-action-container__price" id="sticky-price-display">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
      </div>
      
      {%- assign is_whatsapp_product = false -%}
      {%- for tag in product.tags -%}
        {%- assign tag_downcase = tag | downcase -%}
        {%- if tag_downcase == 'whatsapp-order' or tag_downcase == 'whatsapp' or tag_downcase == 'whatsapp-only' -%}
          {%- assign is_whatsapp_product = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      
      {%- if is_whatsapp_product -%}
        <button type="button" class="btn-whatsapp-order btn--buy-on-whatsapp" style="margin:0 !important;">
          Book on WhatsApp
        </button>
      {%- else -%}
        <button type="button" class="button button--primary" onclick="const atc = document.querySelector('button[name=\'add\']'); if (atc) atc.click();" style="margin:0 !important;">
          Add to Cart
        </button>
      {%- endif -%}
    </div>
  </div>
</product-info>

