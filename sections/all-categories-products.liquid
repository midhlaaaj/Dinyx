{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0

  assign shoes_collection = nil
  for col in collections
    assign col_handle_down = col.handle | downcase
    assign col_title_down = col.title | downcase
    if col_handle_down == 'shoes' or col_title_down == 'shoes' or col_title_down contains 'shoes'
      assign shoes_collection = col
      break
    endif
  endfor
-%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="section-{{ section.id }}-padding">
    {%- comment -%} 1. Render Shoes collection first {%- endcomment -%}
    {%- if shoes_collection != nil and shoes_collection.all_products_count > 0 -%}
      {%- render 'category-slider-item', 
        collection: shoes_collection, 
        section: section, 
        columns_mobile_int: columns_mobile_int, 
        columns_desktop_int: columns_desktop_int 
      -%}
    {%- endif -%}

    {%- comment -%} 2. Render the rest of the collections {%- endcomment -%}
    {%- for collection in collections -%}
      {%- if collection.handle == 'all' or collection.handle == 'frontpage' or collection.handle == 'best-seller' -%}
        {%- continue -%}
      {%- endif -%}
      {%- if shoes_collection != nil and collection.handle == shoes_collection.handle -%}
        {%- continue -%}
      {%- endif -%}

      {%- if collection.all_products_count > 0 -%}
        {%- render 'category-slider-item', 
          collection: collection, 
          section: section, 
          columns_mobile_int: columns_mobile_int, 
          columns_desktop_int: columns_desktop_int 
        -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "All Categories Products",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 8,
      "label": "Products to show per category"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
